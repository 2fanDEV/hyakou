{
  "packageManager": "pnpm",
  "name": "frontend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "wasm:build:dev": "wasm-pack build ../crates/wasm_bindings --target web --out-dir pkg",
    "wasm:build:prod": "wasm-pack build ../crates/wasm_bindings --target web --release --out-dir pkg",
    "predev": "pnpm run wasm:build:dev",
    "dev": "vite dev --port 3000",
    "prebuild": "pnpm run wasm:build:prod",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "pnpm run wasm:build:dev",
    "test": "vitest run --passWithNoTests",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.4.0",
    "@dnd-kit/dom": "^0.4.0",
    "@dnd-kit/react": "^0.4.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "ignoredBuiltDependencies": [
      "msw"
    ]
  }
}
